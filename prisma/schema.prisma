generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum UserPlan {
  FREE
  PREMIUM
}

enum AssetType {
  STOCK
  ETF
  CRYPTO
}

enum TransactionType {
  BUY
  SELL
}

enum CurrencyCode {
  EUR
  USD
}

enum MarketDataProvider {
  FINNHUB
}

enum FxProvider {
  FRANKFURTER
}

enum AlertType {
  PRICE_ABOVE
  PRICE_BELOW
  DAILY_CHANGE_PERCENT
}

enum NotificationType {
  ALERT_TRIGGERED
  SYSTEM
}

enum HoldingStatus {
  OPEN
  CLOSED
}

model User {
  id                String        @id @default(cuid())
  email             String        @unique
  passwordHash      String
  name              String?
  role              UserRole      @default(USER)
  plan              UserPlan      @default(FREE)
  preferredCurrency CurrencyCode  @default(EUR)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  portfolio         Portfolio?
  refreshTokens     RefreshToken[]
  transactions      Transaction[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Portfolio {
  id        String   @id @default(cuid())
  userId    String   @unique
  name      String   @default("My Portfolio")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  holdings     Holding[]
  transactions Transaction[]

  @@map("portfolios")
}

model Asset {
  id             String             @id @default(cuid())
  symbol         String
  name           String
  type           AssetType
  currency       CurrencyCode
  exchange       String?
  provider       MarketDataProvider
  providerSymbol String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  holdings     Holding[]
  transactions Transaction[]

  @@unique([symbol, type])
  @@map("assets")
}

model Holding {
  id              String        @id @default(cuid())
  portfolioId     String
  assetId         String
  quantity        Decimal
  averageBuyPrice Decimal
  totalCost       Decimal
  status          HoldingStatus @default(OPEN)
  currency        CurrencyCode
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  asset     Asset     @relation(fields: [assetId], references: [id])

  @@unique([portfolioId, assetId])
  @@map("holdings")
}

model Transaction {
  id           String          @id @default(cuid())
  portfolioId  String
  assetId      String
  userId       String
  type         TransactionType
  quantity     Decimal
  pricePerUnit Decimal
  fee          Decimal         @default(0)
  currency     CurrencyCode
  grossAmount  Decimal
  netAmount    Decimal
  transactedAt DateTime
  createdAt    DateTime        @default(now())

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  asset     Asset     @relation(fields: [assetId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@map("transactions")
}
