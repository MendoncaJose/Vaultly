generator client {
  provider = "prisma-client-js"
  output   = "../backend/src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum UserPlan {
  FREE
  PREMIUM
}

enum AssetType {
  STOCK
  ETF
  CRYPTO
}

enum TransactionType {
  BUY
  SELL
}

enum CurrencyCode {
  EUR
  USD
}

enum MarketDataProvider {
  FINNHUB
}

enum FxProvider {
  FRANKFURTER
}

enum AlertType {
  PRICE_ABOVE
  PRICE_BELOW
  DAILY_CHANGE_PERCENT
}

enum NotificationType {
  ALERT_TRIGGERED
  SYSTEM
}

enum HoldingStatus {
  OPEN
  CLOSED
}

model User {
  id                String        @id @default(cuid())
  email             String        @unique
  passwordHash      String
  name              String?
  role              UserRole      @default(USER)
  plan              UserPlan      @default(FREE)
  preferredCurrency CurrencyCode  @default(EUR)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  portfolio         Portfolio?
  refreshTokens     RefreshToken[]
  transactions      Transaction[]
  watchlistItems    WatchlistItem[]
  alerts            Alert[]
  notifications     Notification[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Portfolio {
  id        String   @id @default(cuid())
  userId    String   @unique
  name      String   @default("My Portfolio")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  holdings           Holding[]
  transactions       Transaction[]
  portfolioSnapshots PortfolioSnapshot[]

  @@map("portfolios")
}

model Asset {
  id             String             @id @default(cuid())
  symbol         String
  name           String
  type           AssetType
  currency       CurrencyCode
  exchange       String?
  provider       MarketDataProvider
  providerSymbol String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  holdings       Holding[]
  transactions   Transaction[]
  watchlistItems WatchlistItem[]
  alerts         Alert[]

  @@unique([symbol, type])
  @@map("assets")
}

model Holding {
  id              String        @id @default(cuid())
  portfolioId     String
  assetId         String
  quantity        Decimal
  averageBuyPrice Decimal
  totalCost       Decimal
  status          HoldingStatus @default(OPEN)
  currency        CurrencyCode
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  asset     Asset     @relation(fields: [assetId], references: [id])

  @@unique([portfolioId, assetId])
  @@map("holdings")
}

model Transaction {
  id           String          @id @default(cuid())
  portfolioId  String
  assetId      String
  userId       String
  type         TransactionType
  quantity     Decimal
  pricePerUnit Decimal
  fee          Decimal         @default(0)
  currency     CurrencyCode
  grossAmount  Decimal
  netAmount    Decimal
  transactedAt DateTime
  createdAt    DateTime        @default(now())

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  asset     Asset     @relation(fields: [assetId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@map("transactions")
}

model WatchlistItem {
  id        String   @id @default(cuid())
  userId    String
  assetId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset Asset @relation(fields: [assetId], references: [id])

  @@unique([userId, assetId])
  @@map("watchlist_items")
}

model Alert {
  id           String    @id @default(cuid())
  userId       String
  assetId      String
  type         AlertType
  targetValue  Decimal
  isActive     Boolean   @default(true)
  triggeredAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset         Asset          @relation(fields: [assetId], references: [id])
  notifications Notification[]

  @@map("alerts")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  alertId   String?
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  alert Alert? @relation(fields: [alertId], references: [id], onDelete: SetNull)

  @@map("notifications")
}

model PriceSnapshot {
  id            String             @id @default(cuid())
  symbol        String
  assetType     AssetType
  provider      MarketDataProvider
  price         Decimal
  change        Decimal?
  changePercent Decimal?
  currency      CurrencyCode
  capturedAt    DateTime           @default(now())

  @@index([symbol, assetType])
  @@map("price_snapshots")
}

model FxRateSnapshot {
  id           String       @id @default(cuid())
  fromCurrency CurrencyCode
  toCurrency   CurrencyCode
  rate         Decimal
  provider     FxProvider
  capturedAt   DateTime     @default(now())

  @@index([fromCurrency, toCurrency])
  @@map("fx_rate_snapshots")
}

model PortfolioSnapshot {
  id           String       @id @default(cuid())
  portfolioId  String
  totalValue   Decimal
  totalCost    Decimal
  totalPl      Decimal
  currency     CurrencyCode
  snapshotDate DateTime
  createdAt    DateTime     @default(now())

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, snapshotDate])
  @@map("portfolio_snapshots")
}
